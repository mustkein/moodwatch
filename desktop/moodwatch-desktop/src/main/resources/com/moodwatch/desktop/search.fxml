<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.moodwatch.desktop.controller.SearchController"
      styleClass="search-view"
      spacing="16">

    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="search-bar">
        <TextField fx:id="searchField" promptText="Film adı girin..." styleClass="input-field"
                   HBox.hgrow="ALWAYS"/>
        <Button fx:id="searchButton" text="Ara" styleClass="login-button" onAction="#onSearch"/>
    </HBox>

    <ListView fx:id="resultsList" styleClass="results-list" VBox.vgrow="ALWAYS"/>

</VBox>
